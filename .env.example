# James Bond Environment Variables

# Server Port (default :8080)
# JB_SERVER_PORT=:8080

# Runtime Data Directory (default ./data)
# JB_DATA_DIR=./data

# JWT Secret for signing tokens (Required)
JB_JWT_SECRET=replace_me_with_a_long_random_string

# JamesDSP Headless Binary Path (default jamesdsp)
# JB_JAMESDSP_BIN=jamesdsp

# Admin Credentials
JB_ADMIN_USER=admin
JB_ADMIN_PASS=admin123

# Client Tokens (comma-separated list of pre-issued tokens)
JB_CLIENT_TOKENS=token1,token2
